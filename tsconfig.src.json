{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/types/**/*.ts",
    "src/lib/**/*.ts",
    "src/store/**/*.ts",
    "src/hooks/**/*.ts",
    "src/data/dictionaries/**/*.json"
  ]
}
